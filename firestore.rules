rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'hernanpaliza.psic@gmail.com';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Usuarios
    match /usuarios/{uid} {
      // Campos de aprobación manual — inmutables desde cliente.
      // Solo pueden mutar vía Admin SDK (endpoint /api/admin/approve-user)
      // que bypasea rules. En create, el cliente los DEBE setear a los
      // valores iniciales (aprobado:false, estadoAprobacion:'pendiente').
      function camposAprobacionIniciales() {
        return request.resource.data.aprobado == false
          && request.resource.data.estadoAprobacion == 'pendiente';
      }
      function camposAprobacionIntactos() {
        let hoy = resource.data;
        let nuevo = request.resource.data;
        return nuevo.aprobado == hoy.aprobado
          && nuevo.get('estadoAprobacion', null) == hoy.get('estadoAprobacion', null)
          && nuevo.get('fechaAprobacion', null) == hoy.get('fechaAprobacion', null)
          && nuevo.get('fechaRechazo', null) == hoy.get('fechaRechazo', null)
          && nuevo.get('aprobadoPor', null) == hoy.get('aprobadoPor', null);
      }

      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && camposAprobacionIniciales();
      allow update: if isOwner(uid) && camposAprobacionIntactos();
      allow delete: if false;

      // Wearables (Fitbit/Oura/etc.): estado de conexión.
      // Read-only desde cliente. La escritura es exclusiva de Cloud
      // Functions con Admin SDK — el Admin SDK bypassea estas rules.
      match /dispositivos/{deviceId} {
        allow read: if isOwner(uid) || isAdmin();
        // sin allow write/create/update/delete → bloqueado para clientes
      }

      // Mediciones biométricas diarias. Doc id = fecha ISO (ej. "2026-06-16").
      // El cliente (NeuroScan en navegador) puede crear/actualizar el doc,
      // pero NO puede tocar fuentes.reloj — ese bloque solo lo puebla la
      // Cloud Function de sync vía Admin SDK.
      match /mediciones/{fecha} {
        function relojNoDeclarado() {
          return !('reloj' in request.resource.data.fuentes)
            || request.resource.data.fuentes.reloj.disponible == false;
        }
        function relojIntacto() {
          return request.resource.data.fuentes.reloj == resource.data.fuentes.reloj;
        }

        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid)
          && request.resource.data.fecha == fecha
          && 'fuentes' in request.resource.data
          && relojNoDeclarado();
        allow update: if isOwner(uid) && relojIntacto();
        allow delete: if isOwner(uid);
      }
    }

    // Registros diarios
    match /registros/{registroId} {
      allow read, write: if isOwner(resource.data.uid);
      allow create: if isOwner(request.resource.data.uid);
      allow read: if isAdmin();
    }

    // Notas personales
    match /notas/{notaId} {
      allow read, write, delete: if isOwner(resource.data.uid);
      allow create: if isOwner(request.resource.data.uid);
      allow read: if isAdmin();
    }

    // Assessments B2B tokenizados: el ejecutivo llega por link WhatsApp
    // sin cuenta Firebase. Todo I/O va por /api/assessment/* con Admin SDK
    // (bypass rules). El cliente nunca lee ni escribe directo — el token
    // en URL es el único secreto y solo lo interpreta el servidor.
    match /assessments/{tokenId} {
      allow read, write: if false;
    }
  }
}
